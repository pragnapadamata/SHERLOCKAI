# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# The LLM layer is provider-agnostic and tiered. Provider, model, and API key
# all come from here -- nothing is hardcoded. Each tier is configured
# independently, so the small tier could be one provider and the large another.

# --- Application ---
APP_ENV=dev          # dev | prod | test  (controls log rendering)
LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR

# --- LLM small/fast tier (routing, classification, simple sub-tasks) ---
LLM_SMALL_PROVIDER=groq
LLM_SMALL_MODEL=llama-3.1-8b-instant
LLM_SMALL_API_KEY=

# --- LLM large/reasoning tier (diagnosis, root-cause, planning, reports) ---
LLM_LARGE_PROVIDER=groq
LLM_LARGE_MODEL=llama-3.3-70b-versatile
LLM_LARGE_API_KEY=

# --- LLM per-call request timeout (seconds) for the live provider client ---
# A full multi-specialist run makes many large-context calls; a single large-tier
# completion can exceed the SDK default (Groq 60s). Default 180s; raise if needed.
LLM_REQUEST_TIMEOUT=180

# --- Web session signing (set a long random value in production) ---
SESSION_SECRET=change-me-in-production

# --- Microsoft Entra ID SSO (optional) ---
# Leave blank to use the built-in local persona picker. Fill in to enable real
# single sign-on through the OAuth authorization-code flow.
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=common
ENTRA_REDIRECT_URI=http://localhost:8000/api/auth/callback
